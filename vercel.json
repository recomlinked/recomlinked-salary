{
  "outputDirectory": "public",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },

    { "src": "/favicon.ico", "dest": "/favicon.svg" },
    { "src": "/robots.txt",  "dest": "/robots.txt"  },
    { "src": "/sitemap.xml", "dest": "/sitemap.xml" },

    { "src": "/raise",                "dest": "/raise/index.html"           },
    { "src": "/raise/",               "dest": "/raise/index.html"           },
    { "src": "/raise/chat",           "dest": "/raise/chat/index.html"      },
    { "src": "/raise/chat/",          "dest": "/raise/chat/index.html"      },
    { "src": "/raise/paid",           "dest": "/raise/paid/index.html"      },
    { "src": "/raise/paid/",          "dest": "/raise/paid/index.html"      },
    { "src": "/raise/enter",          "dest": "/raise/enter/index.html"     },
    { "src": "/raise/enter/",         "dest": "/raise/enter/index.html"     },
    { "src": "/raise/waitlist",       "dest": "/raise/waitlist/index.html"  },
    { "src": "/raise/waitlist/",      "dest": "/raise/waitlist/index.html"  },

    { "src": "/", "dest": "/index.html" }
  ],
  "functions": {
    "api/raise-webhook.js":      { "memory": 256 },
    "api/raise-enrich.js":       { "memory": 256, "maxDuration": 60 },
    "api/raise-coach.js":        { "memory": 256, "maxDuration": 30 },
    "api/raise-notes-update.js": { "memory": 256, "maxDuration": 30 },
    "api/raise-exchange.js":     { "memory": 256, "maxDuration": 30 },
    "api/raise-analyze.js":      { "memory": 256, "maxDuration": 30 }
  }
}
